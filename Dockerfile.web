FROM node:20-alpine AS builder
WORKDIR /app

RUN npm install -g pnpm@10

COPY package.json pnpm-lock.yaml ./
COPY patches/ ./patches/

# Create a single-package workspace (skip release/app which needs electron-rebuild)
RUN printf 'packages:\n  - .\n' > pnpm-workspace.yaml
RUN echo "shamefully-hoist=true" > .npmrc
RUN pnpm install --no-frozen-lockfile --ignore-scripts

COPY src/ ./src/
COPY vite.web.config.ts postcss.config.js tailwind.config.js tsconfig.json ./

ARG VITE_API_BASE
ARG VITE_MATH_APP_URL
ARG VITE_CALENDAR_APP_URL
ARG VITE_CHESS_APP_URL
ARG VITE_FLASHCARDS_APP_URL

RUN npx vite build --config vite.web.config.ts --mode production

FROM nginx:alpine
COPY --from=builder /app/src/renderer/dist /usr/share/nginx/html
RUN echo 'server { \
    listen 8080; \
    root /usr/share/nginx/html; \
    index index.html; \
    location / { \
        try_files $uri $uri/ /index.html; \
    } \
}' > /etc/nginx/conf.d/default.conf

EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
